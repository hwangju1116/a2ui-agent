[
  {
    "beginRendering": {
      "surfaceId": "category-modal",
      "root": "root",
      "styles": {
        "primaryColor": "#0C4DA2",
        "font": "Roboto"
      }
    }
  },
  {
    "surfaceUpdate": {
      "surfaceId": "category-modal",
      "components": [
        {
          "id": "root",
          "component": {
            "Column": {
              "children": {
                "explicitList": [
                  "title-heading",
                  "category-list"
                ]
              }
            }
          }
        },
        {
          "id": "title-heading",
          "component": {
            "Text": {
              "usageHint": "h3",
              "text": {
                "path": "/title"
              }
            }
          }
        },
        {
          "id": "category-list",
          "component": {
            "List": {
              "direction": "vertical",
              "children": {
                "template": {
                  "componentId": "category-item-template",
                  "dataBinding": "/categories"
                }
              }
            }
          }
        },
        {
          "id": "category-item-template",
          "component": {
            "Card": {
              "child": "category-layout",
              "width": 320,
              "height": 50
            }
          }
        },
        {
          "id": "category-layout",
          "component": {
            "Row": {
              "children": {
                "explicitList": [
                  "image-text-group",
                  "select-button"
                ]
              },
              "distribution": "spaceBetween",
              "alignment": "center"
            }
          }
        },
        {
          "id": "image-text-group",
          "component": {
            "Row": {
              "children": {
                "explicitList": [
                  "category-image",
                  "category-text"
                ]
              },
              "distribution": "start",
              "alignment": "center"
            }
          }
        },
        {
          "id": "category-image",
          "component": {
            "Image": {
              "url": {
                "path": "/imageUrl"
              },
              "fit": "cover",
              "usageHint": "avatar"
            }
          }
        },
        {
          "id": "category-text",
          "component": {
            "Text": {
              "usageHint": "body",
              "text": {
                "path": "/category"
              }
            }
          }
        },
        {
          "id": "select-button",
          "component": {
            "Button": {
              "child": "select-text",
              "primary": true,
              "action": {
                "name": "select_category",
                "context": [
                  {
                    "key": "name",
                    "value": {
                      "path": "/category"
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "id": "select-text",
          "component": {
            "Text": {
              "text": {
                "literalString": "선택"
              }
            }
          }
        }
      ]
    }
  },
  {
    "dataModelUpdate": {
      "surfaceId": "category-modal",
      "path": "/",
      "contents": [
        {
          "key": "title",
          "valueString": "카테고리를 선택해주세요."
        },
        {
          "key": "categories",
          "valueMap": [
            {
              "key": "item1",
              "valueMap": [
                {
                  "key": "category",
                  "valueString": "스마트폰"
                }
              ]
            },
            {
              "key": "item2",
              "valueMap": [
                {
                  "key": "category",
                  "valueString": "태블릿"
                }
              ]
            }
          ]
        }
      ]
    }
  }
]
